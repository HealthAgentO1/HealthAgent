# =============================================================================
# Local environment template
# -----------------------------------------------------------------------------
# 1. Copy this file to `.env` in the **repository root** (same folder as
#    manage.py). Git must never contain real secrets — use `.env` only locally
#    or in your secret manager / deployment platform.
# 2. Share real API keys only through a secure channel (1Password shared vault,
#    encrypted DM, company secrets store, etc.), never in Slack/email/git.
# 3. All four developers: use the same variable *names*; values can match these
#    dev defaults or your own local Postgres/password choices.
# =============================================================================

# --- PostgreSQL (Django + docker-compose `db` service) --------------------
POSTGRES_DB=myprojectdb
POSTGRES_USER=myprojectuser
POSTGRES_PASSWORD=password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Django ------------------------------------------------------------------
# Generate a real key for local/dev:  python -c "from django.core.management.utils import get_random_secret_key as g; print(g())"
DJANGO_SECRET_KEY=replace-me-use-get-random-secret-key-locally
DJANGO_DEBUG=True

# --- Core AI Agent (Deepseek) -----------------------------------------------
# Obtain from Deepseek platform (API key). Used when the backend integrates the
# LLM for symptom chat / triage — keep unset until that code reads this var.
DEEPSEEK_API_KEY=
# Optional. Default OpenAI-compatible base is https://api.deepseek.com
# DEEPSEEK_API_BASE=https://api.deepseek.com

# --- NPPES (CMS NPI Registry) -----------------------------------------------
# No API key — public HTTPS API. Backend will call it server-side; nothing to
# configure here beyond documenting that no credential is required.

# --- Frontend (Vite) ---------------------------------------------------------
# Vite reads env files from the `frontend/` directory. Optional override:
# VITE_API_URL=http://127.0.0.1:8000/api
# (Put that line in `frontend/.env` or `frontend/.env.local`, not committed.)
