# =============================================================================
# Local environment template
# -----------------------------------------------------------------------------
# 1. Copy this file to `.env` in the **repository root** (same folder as
#    manage.py). Git must never contain real secrets — use `.env` only locally
#    or in your secret manager / deployment platform.
# 2. Share real API keys only through a secure channel (1Password shared vault,
#    encrypted DM, company secrets store, etc.), never in Slack/email/git.
# 3. All four developers: use the same variable *names*; values can match these
#    dev defaults or your own local Postgres/password choices.
# =============================================================================

# --- PostgreSQL (Django + docker-compose `db` service) --------------------
POSTGRES_DB=myprojectdb
POSTGRES_USER=myprojectuser
POSTGRES_PASSWORD=password
# Host is `localhost` when Django runs on your machine; `docker compose` sets
# POSTGRES_HOST=db for the Django container automatically (do not rely on
# editing this line for Docker).
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Django ------------------------------------------------------------------
# Generate a real key for local/dev:  python -c "from django.core.management.utils import get_random_secret_key as g; print(g())"
DJANGO_SECRET_KEY=replace-me-use-get-random-secret-key-locally
DJANGO_DEBUG=True

# --- Core AI Agent (symptom interview) --------------------------------------
# Provider: openai (default) = OpenAI-compatible HTTP API — works for OpenAI,
# Deepseek (default when only DEEPSEEK_API_KEY is set), and similar gateways.
# Set LLM_PROVIDER=anthropic to use the Anthropic Messages API instead.
LLM_PROVIDER=openai
LLM_MODEL=deepseek-chat
# Rough token budget for chat history sent to the model (tiktoken estimate).
# LLM_MAX_INPUT_TOKENS=12000

# OpenAI (https://platform.openai.com/) — set OPENAI_BASE_URL only if not using api.openai.com
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# Deepseek — if you do not set OPENAI_API_KEY, the app uses DEEPSEEK_API_KEY and
# DEEPSEEK_API_BASE (OpenAI-compatible).
DEEPSEEK_API_KEY=
# DEEPSEEK_API_BASE=https://api.deepseek.com

# Anthropic (only when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Medication extraction (`POST /api/medication-profile/extract/`) uses the same
# OpenAI-compatible stack as the symptom LLM (defaults: Deepseek when only DEEPSEEK_API_KEY is set).

# openFDA drug labels — optional key for higher rate limits when checking interactions
# (pairwise scan of `drug_interactions` text after extraction). See https://open.fda.gov/apis/
# OPENFDA_API_KEY=
# OPENFDA_LABEL_URL=https://api.fda.gov/drug/label.json
# OPENFDA_CACHE_TTL_SECONDS=86400
# OPENFDA_REQUEST_TIMEOUT=25

# --- NPPES (CMS NPI Registry) -----------------------------------------------
# No API key — public HTTPS API. Backend will call it server-side; nothing to
# configure here beyond documenting that no credential is required.

# --- Frontend (Vite) ---------------------------------------------------------
# Vite reads env files from the `frontend/` directory. Optional overrides
# (put these in `frontend/.env` or `frontend/.env.local`, not committed):
# VITE_API_URL=http://127.0.0.1:8000/api
#
# Symptom Check calls Django `POST /api/symptom/survey-llm/` via Axios (`apiClient`)
# using the bundled prompts + JWT (`access_token` in localStorage). No extra
# Vite URL is required for the survey LLM beyond `VITE_API_URL`.
